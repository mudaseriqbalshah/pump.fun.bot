# ============================================================
# Pump.fun Bot — Environment Variables
# Copy this file to .env and fill in all values.
# NEVER commit .env to version control.
# ============================================================

# Node environment
NODE_ENV=production

# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# -----------------------------------------------------------
# Solana Wallet
# -----------------------------------------------------------
# Base58-encoded private key for the trading wallet.
# Generate with: solana-keygen new --outfile ~/.config/solana/id.json
# Then export: cat ~/.config/solana/id.json | python3 -c "import sys,json,base58; k=json.load(sys.stdin); print(base58.b58encode(bytes(k)).decode())"
WALLET_PRIVATE_KEY=

# -----------------------------------------------------------
# QuickNode RPC Endpoints (add up to 10)
# -----------------------------------------------------------
RPC_URL_1=https://your-quicknode-1.solana-mainnet.quiknode.pro/TOKEN/.env.example
RPC_URL_2=https://your-quicknode-2.solana-mainnet.quiknode.pro/TOKEN/
RPC_URL_3=
RPC_URL_4=
RPC_URL_5=
RPC_URL_6=
RPC_URL_7=
RPC_URL_8=
RPC_URL_9=
RPC_URL_10=

# -----------------------------------------------------------
# Telegram User Account (gramjs MTProto — for reading channels)
# Get API ID and hash at: https://my.telegram.org/apps
# -----------------------------------------------------------
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=+1234567890

# -----------------------------------------------------------
# Discord Bot Token (for reading signal channels)
# Create a bot at: https://discord.com/developers/applications
# -----------------------------------------------------------
DISCORD_BOT_TOKEN=

# -----------------------------------------------------------
# Notification Telegram Bot (sends YOU trade alerts)
# Create via @BotFather, then message your bot to get chat ID.
# -----------------------------------------------------------
NOTIFY_TELEGRAM_BOT_TOKEN=
NOTIFY_TELEGRAM_CHAT_ID=
