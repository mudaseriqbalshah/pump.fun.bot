{
  "name": "pump-fun-bot",
  "version": "1.0.0",
  "description": "Pump.fun day trading bot — TypeScript",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "setup-db": "tsx scripts/setup-db.ts",
    "check-rpc": "tsx scripts/check-rpc.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "pumpdotfun-sdk": "^1.4.2",
    "@solana/web3.js": "^1.95.4",
    "@jup-ag/api": "^6.0.0",
    "better-sqlite3": "^11.0.0",
    "discord.js": "^14.15.3",
    "dotenv": "^16.4.5",
    "telegram": "^2.26.22",
    "js-yaml": "^4.1.0",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.16.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
